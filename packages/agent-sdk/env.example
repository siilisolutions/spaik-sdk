# API keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
XAI_API_KEY=your-xai-api-key
COHERE_API_KEY=your-cohere-api-key
MISTRAL_API_KEY=your-mistral-api-key

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514

# Azure has two provider modes. Use one MODEL_PROVIDER at a time.

# Azure OpenAI (older *.openai.azure.com endpoint style)
MODEL_PROVIDER=azure
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-15-preview
AZURE_API_KEY=your-azure-api-key

# Azure AI Foundry project endpoint (newer project format)
# MODEL_PROVIDER=foundry
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_FOUNDRY_API_KEY=your-foundry-api-key

# Azure deployment names. Set the one(s) your DEFAULT_MODEL / app uses.
AZURE_GPT_4_1_DEPLOYMENT=your-gpt-4-1-deployment
AZURE_GPT_4_1_MINI_DEPLOYMENT=your-gpt-4-1-mini-deployment
AZURE_GPT_4O_DEPLOYMENT=your-gpt-4o-deployment
AZURE_GPT_4O_MINI_DEPLOYMENT=your-gpt-4o-mini-deployment
AZURE_GPT_5_DEPLOYMENT=your-gpt-5-deployment
AZURE_GPT_5_MINI_DEPLOYMENT=your-gpt-5-mini-deployment
AZURE_CLAUDE_SONNET_4_6_DEPLOYMENT=your-claude-sonnet-deployment
AZURE_DEEPSEEK_V3_2_DEPLOYMENT=your-deepseek-v3-2-deployment
AZURE_MISTRAL_LARGE_3_DEPLOYMENT=your-mistral-large-deployment
AZURE_LLAMA_4_MAVERICK_DEPLOYMENT=your-llama-4-maverick-deployment
AZURE_COHERE_COMMAND_A_DEPLOYMENT=your-cohere-command-a-deployment
AZURE_GROK_4_DEPLOYMENT=your-grok-4-deployment
AZURE_KIMI_K2_THINKING_DEPLOYMENT=your-kimi-k2-thinking-deployment

# Image Generation
IMAGE_MODEL=gpt-image-1.5

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# Auth Bypass (Development Only)
# Set to 'true' to bypass token validation - WARNING: Only use in development
AUTH_BYPASS=false
AUTH_BYPASS_TOKEN=dev-bypass-token

# Microsoft Entra ID (Azure AD) Configuration
MS_TENANT_ID=your-tenant-id
MS_AUDIENCE=your-api-client-id
# Optional - will be auto-generated if not provided
MS_ISSUER=https://login.microsoftonline.com/your-tenant-id/v2.0 